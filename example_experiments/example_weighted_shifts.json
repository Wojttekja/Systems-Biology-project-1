{
  "name": "example_weighted_shifts",
  "description": "Example using WeightedShiftsMutation: directional mutations weighted by individual-specific weights that adapt over time via polynomial fitting.",
  "group": "Examples",
  "n": 4,
  "N": 100,
  "sigma": 0.2,
  "threshold": 0.01,
  "init_scale": 0.1,
  "max_generations": 150,
  "n_replicates": 5,
  "seeds": [42, 43, 44, 45, 46],

  "environment": {
    "type": "linear_shift",
    "params": {
      "c": 0.012,
      "delta": 0.01
    }
  },

  "mutation_strategy": {
    "type": "weighted_shifts",
    "params": {
      "mu": 0.1,
      "mu_c": 0.5,
      "xi": 0.05,
      "k": 8,
      "b": 0.4
    }
  },

  "init_weights": 1.0,
  "lambdas": 0.5
}

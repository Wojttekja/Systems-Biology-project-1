{
  "name": "example_adaptive_directional",
  "description": "Example using AdaptiveDirectionalMutation: individuals use per-dimension lambdas to adaptively blend isotropic and directional drift.",
  "group": "Examples",
  "n": 4,
  "N": 100,
  "sigma": 0.2,
  "threshold": 0.01,
  "init_scale": 0.1,
  "max_generations": 150,
  "n_replicates": 5,
  "seeds": [50, 51, 52, 53, 54],

  "environment": {
    "type": "linear_shift",
    "params": {
      "c": 0.012,
      "delta": 0.01
    }
  },

  "mutation_strategy": {
    "type": "adaptive_directional",
    "params": {
      "mu": 0.1,
      "mu_c": 0.5,
      "xi": 0.05
    }
  },

  "init_weights": 1.0,
  "lambdas": 0.5
}
